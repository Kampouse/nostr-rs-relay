{
  "$schema": "https://railway.com/railwayApp.schema/v2",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
    "buildContext": "."
  },
  "deploy": {
    "startCommand": "./nostr-rs-relay --db /usr/src/app/db",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_failure",
    "replicas": 1
  }
}
